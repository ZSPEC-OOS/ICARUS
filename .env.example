# ── Firebase configuration ────────────────────────────────────────────────────
# Required for cloud sync, authentication, and cross-device settings persistence.
# Create a Firebase project at https://console.firebase.google.com and copy the
# values from Project Settings → Your apps → Web app → SDK snippet.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── AI proxy ──────────────────────────────────────────────────────────────────
# Optional: route AI API calls through a backend proxy instead of calling providers directly from the browser.
# Leave blank to use the built-in Vite dev proxy (development only).
VITE_AI_PROXY_URL=

# E2B cloud sandbox API key (https://e2b.dev) — enables sandboxed code execution in production.
# Leave blank to fall back to the local exec bridge (dev only) or Docker.
VITE_E2B_API_KEY=

# Docker-based execution backend — alternative to E2B for self-hosted sandboxes.
VITE_DOCKER_HOST=
VITE_DOCKER_CONTAINER=

# Execution relay URL — used when neither E2B nor Docker is available and a custom relay is preferred.
VITE_EXEC_RELAY=

# Execution backend selector: auto | e2b | docker | relay | local
# "auto" picks the first available backend in the order above.
VITE_EXEC_BACKEND=auto

# ── V2 Feature Flags ──────────────────────────────────────────────────────────
# All default to false except VITE_TELEMETRY. Changes require page refresh.
# Quick testing via URL params: ?v2=true&v2ui=true
# Persistent testing via localStorage: see docs/MIGRATION.md

# V2 deterministic task state machine (Phases 1–4)
VITE_V2_ENGINE=false
# V2 task dashboard UI (Phase 7)
VITE_V2_UI=false
# V2 context budget system (Phase 3)
VITE_V2_CONTEXT=false
# Structural loop prevention guards (Phase 4)
VITE_V2_LOOP=false
# Safety gates + quality signals (Phase 5)
VITE_V2_RELIABILITY=false
# Thin V2 tool executor, no auto-hooks (Phase 2)
VITE_V2_EXECUTOR=false
# Human plan approval checkpoint
VITE_PLAN_REVIEW=false
# Human cycle review checkpoint
VITE_CYCLE_REVIEW=false
# Structured telemetry events (safe to leave enabled)
VITE_TELEMETRY=true
# Resource limit overrides
VITE_MAX_CYCLES=3
VITE_MAX_TURNS=25
VITE_CONTEXT_WINDOW=128000
VITE_REMEDIATION_BUDGET=100
